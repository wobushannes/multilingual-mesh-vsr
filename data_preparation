class OptimizedVideoProcessor:
    def __init__(self, hdf5_db: OptimizedHDF5Database):
        self.hdf5_db = hdf5_db
        self.mediapipe = OptimizedMediaPipeProcessor()
        self.whisper = WhisperProcessor()
        self.stop_requested = False
        
    def stop(self):
        self.stop_requested = True
        logger.warning("⏹ Stopp angefordert...")
        
    def process_video_pipelined(self, video_path: str, callback=None) -> bool:
        """
        Verarbeitet Video mit NULL TOLERANZ für Müll
        """
        self.stop_requested = False
        
        try:
            video_path = Path(video_path)
            video_id = video_path.stem
            
            # Prüfen ob Video bereits verarbeitet
            with h5py.File(self.hdf5_db.hdf5_path, 'r') as f:
                if 'videos' in f and video_id in f['videos']:
                    msg = f"⚠️ Video bereits in Datenbank: {video_id}"
                    logger.warning(msg)
                    if callback: callback(msg)
                    return False
            
            # 1. Video-Info sammeln
            cap = cv2.VideoCapture(str(video_path))
            if not cap.isOpened():
                msg = f"❌ Konnte Video nicht öffnen: {video_path}"
                logger.error(msg)
                if callback: callback(msg)
                return False
            
            fps = cap.get(cv2.CAP_PROP_FPS)
            total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
            
            msg = f"\n{'='*60}\n📹 {video_path.name}\nFPS: {fps:.2f}, Frames: {total_frames}\n{'='*60}"
            logger.info(msg)
            if callback: callback(msg)
            
            # 2. Whisper im SEPARATEN Thread starten (parallel!)
            whisper_future = None
            with ThreadPoolExecutor(max_workers=2) as executor:
                whisper_future = executor.submit(self.whisper.transcribe, str(video_path), fps)
                
                # 3. WÄHREND Whisper läuft, Landmarks extrahieren (NULL TOLERANZ!)
                self.mediapipe.fps = fps
                self.mediapipe.reset_stats()
                
                batch_size = config.VIDEO_BATCH_SIZE
                
                frame_idx = 0
                success_count = 0
                
                # Batches sammeln für effizienten HDF5-Write
                landmarks_batches = []
                indices_batches = []
                timestamps_batches = []
                current_batch_frames = []
                
                while not self.stop_requested:
                    ret, frame = cap.read()
                    if not ret:
                        break
                    
                    current_batch_frames.append(frame)
                    
                    if len(current_batch_frames) >= batch_size:
                        # Batch verarbeiten
                        landmarks, indices, timestamps = self.mediapipe.process_batch(
                            current_batch_frames, 
                            frame_idx - len(current_batch_frames) + 1
                        )
                        
                        if len(landmarks) > 0:
                            landmarks_batches.append(landmarks)
                            indices_batches.append(indices)
                            timestamps_batches.append(timestamps)
                            success_count += len(landmarks)
                        
                        current_batch_frames = []
                        
                        # Alle config.FRAMES_PER_BATCH Frames in HDF5 speichern
                        total_processed = sum(len(l) for l in landmarks_batches)
                        if total_processed >= config.FRAMES_PER_BATCH:
                            self.hdf5_db.add_frames_batch(
                                video_id=video_id,
                                landmarks_list=landmarks_batches,
                                indices_list=indices_batches,
                                timestamps_list=timestamps_batches
                            )
                            landmarks_batches = []
                            indices_batches = []
                            timestamps_batches = []
                    
                    frame_idx += 1
                    
                    if frame_idx % config.PROGRESS_UPDATE == 0:
                        rate = (success_count / frame_idx) * 100 if frame_idx > 0 else 0
                        msg = f"  📊 {frame_idx}/{total_frames} Frames, Erfolg: {success_count} ({rate:.1f}%)"
                        if callback: callback(msg)
                
                # Rest-Batch verarbeiten
                if current_batch_frames:
                    landmarks, indices, timestamps = self.mediapipe.process_batch(
                        current_batch_frames, 
                        frame_idx - len(current_batch_frames)
                    )
                    if len(landmarks) > 0:
                        landmarks_batches.append(landmarks)
                        indices_batches.append(indices)
                        timestamps_batches.append(timestamps)
                        success_count += len(landmarks)
                
                # Letzte Batches in HDF5 speichern
                if landmarks_batches:
                    self.hdf5_db.add_frames_batch(
                        video_id=video_id,
                        landmarks_list=landmarks_batches,
                        indices_list=indices_batches,
                        timestamps_list=timestamps_batches
                    )
                
                cap.release()
                
                if self.stop_requested:
                    msg = "⏹ Verarbeitung gestoppt"
                    logger.warning(msg)
                    if callback: callback(msg)
                    return False
                
                # 4. Jetzt auf Whisper-Ergebnis warten
                try:
                    segments, full_text = whisper_future.result()
                except Exception as e:
                    logger.error(f"❌ Whisper-Fehler im Future: {e}")
                    segments, full_text = [], ""
                
            # 5. Metadaten speichern (NUR wenn es Frames gibt)
            if success_count > 0:
                mp_stats = self.mediapipe.get_stats()
                wh_stats = self.whisper.get_stats()
                
                self.hdf5_db.add_video_metadata(
                    video_id=video_id,
                    video_path=str(video_path),
                    fps=fps,
                    total_frames=total_frames,
                    successful_frames=success_count,
                    segments=segments,
                    mediapipe_stats=mp_stats,
                    whisper_stats=wh_stats
                )
                
                msg = f"\n✅ FERTIG: {success_count}/{total_frames} Frames ({success_count/total_frames*100:.1f}%), {len(segments)} Segmente"
                logger.success(msg)
                if callback: callback(msg)
                
                return True
            else:
                msg = "❌ Keine erfolgreichen Frames - Video komplett verworfen!"
                logger.error(msg)
                if callback: callback(msg)
                return False
                
        except Exception as e:
            msg = f"❌ FEHLER: {e}\n{traceback.format_exc()}"
            logger.error(msg)
            if callback: callback(msg)
            return False
        finally:
            self.mediapipe.close()

