class FileRandomizer:
    @staticmethod
    def generate_random_name(length: int = 12) -> str:
        chars = string.ascii_lowercase + string.digits
        return ''.join(random.choice(chars) for _ in range(length))
    
    @staticmethod
    def randomize_folder(folder_path: str, extensions: List[str] = None,
                        name_length: int = 12, dry_run: bool = False,
                        callback=None) -> Tuple[int, List[Tuple[str, str]]]:
        folder = Path(folder_path)
        if not folder.exists():
            if callback: callback(f"❌ Ordner nicht gefunden: {folder_path}")
            return 0, []
        
        files = []
        if extensions:
            for ext in extensions:
                ext = ext.lower().strip()
                if not ext.startswith('.'):
                    ext = '.' + ext
                files.extend([f for f in folder.glob(f'*{ext}') if f.is_file()])
                files.extend([f for f in folder.glob(f'*{ext.upper()}') if f.is_file()])
        else:
            files = [f for f in folder.iterdir() if f.is_file()]
        
        files = sorted(list(set(files)))
        
        if not files:
            if callback: callback("⚠️ Keine Dateien gefunden")
            return 0, []
        
        if callback:
            callback(f"📂 Gefundene Dateien: {len(files)}")
            if dry_run: callback("🔍 TROCKENLAUF")
        
        renamed_count = 0
        changes = []
        used_names = set()
        
        for i, file_path in enumerate(files):
            try:
                suffix = file_path.suffix.lower()
                
                while True:
                    new_name = FileRandomizer.generate_random_name(name_length) + suffix
                    new_path = file_path.parent / new_name
                    if new_name not in used_names and not new_path.exists():
                        used_names.add(new_name)
                        break
                
                if not dry_run:
                    file_path.rename(new_path)
                
                renamed_count += 1
                changes.append((str(file_path.name), new_name))
                
                if callback:
                    callback(f"  {i+1:3d}. {file_path.name} → {new_name}")
                
            except Exception as e:
                if callback: callback(f"  ❌ Fehler: {e}")
        
        if callback:
            callback(f"\n{'='*50}")
            if dry_run:
                callback(f"🔍 TROCKENLAUF: {renamed_count} Dateien würden umbenannt")
            else:
                callback(f"✅ {renamed_count} Dateien umbenannt")
        
        return renamed_count, changes

