    def log_message(self, msg):
        self.log_text.insert("end", msg + "\n")
        self.log_text.see("end")
        self.root.update()
    
    def update_stats_display(self):
        stats = self.hdf5_db.get_stats()
        self.stats_text.delete(1.0, tk.END)
        
        video_ids_status = "✅" if stats['video_ids_ok'] else "❌"
        coverage = (stats['frames_in_segments'] / stats['total_frames'] * 100) if stats['total_frames'] > 0 else 0
        
        stats_str = f"""
Frames: {stats['total_frames']:,}
In Segmenten: {stats['frames_in_segments']:,}
Abdeckung: {coverage:.1f}%
Dim: {stats['feature_dim']}
video_ids: {video_ids_status}
Videos: {stats['total_videos']}
Segmente: {stats['total_segments']}
Ø Länge: {stats['avg_frames_per_segment']:.1f} Fr
Größe: {stats['file_size_gb']:.1f} GB
"""
        self.stats_text.insert(1.0, stats_str)
    
    def select_video(self):
        path = filedialog.askopenfilename(filetypes=[("Video", "*.mp4 *.avi *.mov")])
        if path:
            self.start_processing(path, False)
    
    def select_folder(self):
        path = filedialog.askdirectory()
        if path:
            self.start_processing(path, True)
    
    def start_processing(self, path: str, folder: bool):
        self.processing = True
        self.status_label.config(text="● VERARBEITE...", fg="orange")
        self.progress.start()
        self.video_btn.config(state="disabled")
        self.folder_btn.config(state="disabled")
        self.stop_btn.config(state="normal")
        
        def run():
            try:
                if folder:
                    if self.parallel_var.get():
                        result = self.folder_processor.process_folder_parallel(path, self.log_message)
                    else:
                        # Single-threaded für maximale Sicherheit
                        for video_path in sorted(Path(path).glob("*.[mM][pP]4")):  # Nur mp4
                            if self.single_processor.stop_requested:
                                break
                            self.single_processor.process_video_pipelined(str(video_path), self.log_message)
                else:
                    result = self.single_processor.process_video_pipelined(path, self.log_message)
            except Exception as e:
                self.log_message(f"❌ FEHLER: {e}")
                traceback.print_exc()
            finally:
                self.root.after(0, self.processing_finished)
        
        thread = threading.Thread(target=run, daemon=True)
        thread.start()
    
    def processing_finished(self):
        self.processing = False
        self.status_label.config(text="● BEREIT", fg="green")
        self.progress.stop()
        self.video_btn.config(state="normal")
        self.folder_btn.config(state="normal")
        self.stop_btn.config(state="disabled")
        self.update_stats_display()
        
        # Backup-Check nach Verarbeitung
        BackupManager.check_and_backup(self.hdf5_db.hdf5_path)
    
    def stop_processing(self):
        self.single_processor.stop()
        self.folder_processor.stop()
        self.log_message("⏹ Stoppe...")
    
    def change_database(self):
        path = filedialog.askopenfilename(filetypes=[("HDF5", "*.h5")])
        if path:
            config.HDF5_FILE = Path(path)
            self.hdf5_db = OptimizedHDF5Database(config.HDF5_FILE)
            self.single_processor = OptimizedVideoProcessor(self.hdf5_db)
            self.folder_processor = OptimizedFolderProcessor(self.hdf5_db)
            self.db_label.config(text=f"DB: {config.HDF5_FILE}")
            self.update_stats_display()
    
    def create_backup(self):
        try:
            BackupManager.create_backup(self.hdf5_db.hdf5_path, "manual")
            messagebox.showinfo("Backup", "Backup erstellt!")
        except Exception as e:
            messagebox.showerror("Fehler", str(e))
    
    def show_statistics(self):
        viewer = StatisticsViewer(self.root, self.hdf5_db)
        viewer.show()
    
    def show_randomizer(self):
        randomizer = RandomizerGUI(self.root)
        randomizer.show()
    
    def run(self):
        self.root.mainloop()

