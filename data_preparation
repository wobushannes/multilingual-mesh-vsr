class WhisperProcessor:
    def __init__(self):
        self.model = None
        self.stats = {
            'segments': 0,
            'segments_empty': 0,
            'segments_punctuation': 0,
            'segments_too_short': 0,
            'words': 0,
            'duration': 0
        }
        
    def load_model(self):
        logger.info(f"Lade Whisper Modell ({config.WHISPER_MODEL})...")
        self.model = whisper.load_model(
            config.WHISPER_MODEL,
            device=config.CUDA_DEVICE
        )
        logger.info("✅ Whisper Modell geladen")
    
    def _check_segment_quality(self, text: str, start_frame: int, end_frame: int, fps: float) -> bool:
        """Prüft ob Segment brauchbar ist - NULL TOLERANZ"""
        
        # Leerer Text?
        if not text or not text.strip():
            self.stats['segments_empty'] += 1
            return False
        
        text = text.strip()
        
        # Zu kurz?
        if len(text) < config.MIN_TEXT_LENGTH:
            self.stats['segments_too_short'] += 1
            return False
        
        # Nur Sonderzeichen?
        if all(c in '.,!?;: ' for c in text):
            self.stats['segments_punctuation'] += 1
            return False
        
        # Frame-Länge vs Wortanzahl
        frame_count = end_frame - start_frame
        word_count = len(text.split())
        
        if word_count > frame_count * config.MAX_WORDS_PER_FRAME:
            self.stats['segments_too_many_words'] = self.stats.get('segments_too_many_words', 0) + 1
            return False
        
        return True
        
    def transcribe(self, video_path: str, fps: float) -> Tuple[List[dict], str]:
        if self.model is None:
            self.load_model()
            
        logger.info(f"Transkribiere: {Path(video_path).name}")
        
        try:
            result = self.model.transcribe(
                video_path,
                word_timestamps=True,
                language=config.WHISPER_LANGUAGE,
                fp16=torch.cuda.is_available(),
                verbose=False
            )
            
            segments = []
            self.stats['words'] = 0
            self.stats['duration'] = 0
            
            if result is not None and isinstance(result, dict):
                self.stats['duration'] = result.get('duration', 0)
                
                if "segments" in result and result["segments"] is not None:
                    for segment in result["segments"]:
                        if segment is None:
                            continue
                        
                        text = segment.get('text', '').strip()
                        start = segment.get('start', 0.0)
                        end = segment.get('end', 0.0)
                        start_frame = int(start * fps)
                        end_frame = int(end * fps)
                        
                        # NULL TOLERANZ: Qualitätscheck
                        if not self._check_segment_quality(text, start_frame, end_frame, fps):
                            continue
                        
                        seg_dict = {
                            'id': segment.get('id', 0),
                            'start': start,
                            'end': end,
                            'start_frame': start_frame,
                            'end_frame': end_frame,
                            'text': text,
                            'words': []
                        }
                        
                        # Wörter extrahieren (optional)
                        if 'words' in segment and segment['words'] is not None:
                            for word in segment['words']:
                                if word is None or not isinstance(word, dict):
                                    continue
                                    
                                word_dict = {
                                    'text': word.get('word', ''),
                                    'start': word.get('start', 0.0),
                                    'end': word.get('end', 0.0),
                                    'start_frame': int(word.get('start', 0.0) * fps),
                                    'end_frame': int(word.get('end', 0.0) * fps)
                                }
                                seg_dict['words'].append(word_dict)
                                self.stats['words'] += 1
                        
                        segments.append(seg_dict)
                else:
                    logger.warning(f"⚠️ Keine Segmente in Whisper-Ergebnis für {Path(video_path).name}")
            
            self.stats['segments'] = len(segments)
            
            full_text = " ".join([s['text'] for s in segments])
            
            logger.info(f"✅ Transkription: {len(segments)} gültige Segmente von {self.stats['segments'] + self.stats['segments_empty'] + self.stats['segments_punctuation'] + self.stats['segments_too_short']} insgesamt")
            return segments, full_text
            
        except Exception as e:
            logger.error(f"❌ Whisper-Fehler bei {Path(video_path).name}: {e}")
            traceback.print_exc()
            return [], ""
    
    def get_stats(self) -> dict:
        return self.stats

