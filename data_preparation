class OptimizedHDF5Database:
    def __init__(self, hdf5_path: Path):
        self.hdf5_path = Path(hdf5_path)
        self.current_size = 0
        self.input_dim = None
        self._init_database()
        
        # HDF5 Cache optimieren
        import h5py._hl.files
        h5py._hl.files.CACHE_SIZE = config.HDF5_CHUNK_CACHE_MB * 1024 * 1024
        
        # Backup-Check beim Start
        BackupManager.check_and_backup(hdf5_path)
        
    def _init_database(self):
        """Initialisiert die Datenbank - ALLES wird angelegt, NICHTS wird gelöscht"""
        self.hdf5_path.parent.mkdir(exist_ok=True)
        
        if not self.hdf5_path.exists():
            with h5py.File(self.hdf5_path, 'w') as f:
                # landmarks (Hauptdaten)
                f.create_dataset(
                    'landmarks',
                    shape=(0, 1),
                    maxshape=(None, None),
                    dtype=np.float32,
                    compression="gzip",
                    chunks=(2048, 1434),
                    shuffle=True,
                    fletcher32=True
                )
                
                # frame_indices (optional, aber nützlich)
                f.create_dataset(
                    'frame_indices',
                    shape=(0,),
                    maxshape=(None,),
                    dtype=np.int32,
                    compression="gzip",
                    chunks=(2048,)
                )
                
                # timestamps (wichtig für Sync)
                f.create_dataset(
                    'timestamps',
                    shape=(0,),
                    maxshape=(None,),
                    dtype=np.float32,
                    compression="gzip",
                    chunks=(2048,)
                )
                
                # video_ids (KRITISCH! Darf NIEMALS fehlen)
                f.create_dataset(
                    'video_ids',
                    shape=(0,),
                    maxshape=(None,),
                    dtype=h5py.string_dtype(encoding='utf-8'),
                    compression="gzip",
                    chunks=(2048,)
                )
                
                # videos Gruppe (Metadaten pro Video)
                f.create_group('videos')
                
                # segments Gruppe (Transkripte)
                f.create_group('segments')
                
                logger.info(f"✅ Neue Datenbank erstellt: {self.hdf5_path}")
                logger.info("   ✅ ALLE erforderlichen Gruppen/Datasets angelegt")
        
        # Prüfe ob ALLES vorhanden ist (falls alte DB geladen wird)
        with h5py.File(self.hdf5_path, 'a') as f:
            required_datasets = ['landmarks', 'frame_indices', 'timestamps', 'video_ids']
            required_groups = ['videos', 'segments']
            
            for ds in required_datasets:
                if ds not in f:
                    logger.error(f"❌ KRITISCH: Dataset '{ds}' fehlt!")
                    if ds == 'video_ids':
                        logger.error("   video_ids fehlt - Datenbank ist unbrauchbar für Training!")
                        logger.error("   Starte NEUEN Datensatz oder rekonstruiere aus segments")
            
            for grp in required_groups:
                if grp not in f:
                    logger.warning(f"⚠️ Gruppe '{grp}' fehlt - wird neu angelegt")
                    f.create_group(grp)
            
            # Aktuelle Größe lesen
            if 'landmarks' in f:
                self.current_size = f['landmarks'].shape[0]
                if self.current_size > 0:
                    self.input_dim = f['landmarks'].shape[1]
    
    def add_frames_batch(self, video_id: str, landmarks_list: List[np.ndarray], 
                         indices_list: List[np.ndarray], timestamps_list: List[np.ndarray]):
        """Fügt mehrere Batches auf einmal hinzu - NUR perfekte Frames"""
        if not landmarks_list:
            return
            
        total_frames = sum(len(l) for l in landmarks_list)
        if total_frames == 0:
            return
            
        feature_dim = landmarks_list[0].shape[1]
        
        # Alle Daten zu einem großen Array kombinieren
        all_landmarks = np.concatenate(landmarks_list, axis=0)
        all_indices = np.concatenate(indices_list, axis=0)
        all_timestamps = np.concatenate(timestamps_list, axis=0)
        
        with h5py.File(self.hdf5_path, 'a') as f:
            # Dimension prüfen und anpassen (nur wenn nötig)
            if f['landmarks'].shape[1] != feature_dim:
                logger.info(f"📐 Dimension angepasst: {feature_dim}")
                # Alte Daten sichern
                old_landmarks = f['landmarks'][:]
                old_indices = f['frame_indices'][:]
                old_timestamps = f['timestamps'][:]
                old_video_ids = f['video_ids'][:]
                
                # Neu anlegen mit richtiger Dimension
                del f['landmarks']
                f.create_dataset(
                    'landmarks',
                    data=old_landmarks,
                    maxshape=(None, feature_dim),
                    dtype=np.float32,
                    compression="gzip",
                    chunks=(2048, feature_dim)
                )
            
            # Resize (nur wenn nötig)
            new_size = self.current_size + total_frames
            current_max = f['landmarks'].shape[0]
            
            if new_size > current_max:
                f['landmarks'].resize((new_size, feature_dim))
                f['frame_indices'].resize((new_size,))
                f['timestamps'].resize((new_size,))
                f['video_ids'].resize((new_size,))
            
            # Daten schreiben
            f['landmarks'][self.current_size:new_size] = all_landmarks
            f['frame_indices'][self.current_size:new_size] = all_indices
            f['timestamps'][self.current_size:new_size] = all_timestamps
            f['video_ids'][self.current_size:new_size] = [video_id.encode()] * total_frames
            
            self.current_size = new_size
            self.input_dim = feature_dim
    
    def add_video_metadata(self, video_id: str, video_path: str, 
                          fps: float, total_frames: int, 
                          successful_frames: int, segments: List[dict],
                          mediapipe_stats: dict, whisper_stats: dict):
        """Speichert Video-Metadaten - ALLES bleibt erhalten"""
        with h5py.File(self.hdf5_path, 'a') as f:
            # Sicherstellen dass Gruppen existieren
            if 'videos' not in f:
                f.create_group('videos')
            if 'segments' not in f:
                f.create_group('segments')
            
            # Video-Metadaten
            video_group = f['videos'].create_group(video_id)
            video_group.attrs['path'] = str(video_path)
            video_group.attrs['fps'] = fps
            video_group.attrs['total_frames'] = total_frames
            video_group.attrs['successful_frames'] = successful_frames
            video_group.attrs['success_rate'] = (successful_frames / max(1, total_frames)) * 100
            video_group.attrs['date_processed'] = datetime.now().isoformat()
            video_group.attrs['feature_dim'] = self.input_dim
            
            # MediaPipe Statistiken
            for key, value in mediapipe_stats.items():
                video_group.attrs[f'mp_{key}'] = value
            
            # Whisper Statistiken
            for key, value in whisper_stats.items():
                video_group.attrs[f'whisper_{key}'] = value
            
            # Segmente (NUR die guten)
            if segments:
                seg_group = f['segments'].create_group(video_id)
                seg_group.attrs['count'] = len(segments)
                
                for i, seg in enumerate(segments):
                    s = seg_group.create_group(f'segment_{i:04d}')
                    s.attrs['start'] = seg['start']
                    s.attrs['end'] = seg['end']
                    s.attrs['start_frame'] = seg['start_frame']
                    s.attrs['end_frame'] = seg['end_frame']
                    s.attrs['text'] = seg['text']
                    
                    if seg.get('words'):
                        words_group = s.create_group('words')
                        for j, word in enumerate(seg['words']):
                            w = words_group.create_group(f'word_{j:04d}')
                            w.attrs['text'] = word['text']
                            w.attrs['start'] = word['start']
                            w.attrs['end'] = word['end']
                            w.attrs['start_frame'] = word['start_frame']
                            w.attrs['end_frame'] = word['end_frame']
    
    def get_stats(self) -> dict:
        """Gibt aktuelle Datenbank-Statistiken zurück - JETZT KORREKT!"""
        try:
            with h5py.File(self.hdf5_path, 'r') as f:
                total_frames = f['landmarks'].shape[0] if 'landmarks' in f else 0
                feature_dim = f['landmarks'].shape[1] if total_frames > 0 else 0
                total_videos = len(f['videos']) if 'videos' in f else 0
                
                # SEGMENTE und FRAMES IN SEGMENTEN korrekt berechnen
                total_segments = 0
                frames_in_segments = 0
                
                if 'segments' in f:
                    for video_id in f['segments']:
                        for seg_name in f['segments'][video_id]:
                            total_segments += 1
                            seg = f['segments'][video_id][seg_name]
                            start = seg.attrs['start_frame']
                            end = seg.attrs['end_frame']
                            frames_in_segments += (end - start)
                
                file_size = os.path.getsize(self.hdf5_path) / (1024 * 1024 * 1024)  # GB
                
                # Video-IDs prüfen
                video_ids_ok = 'video_ids' in f and f['video_ids'].shape[0] == total_frames
                
                return {
                    'total_frames': total_frames,
                    'frames_in_segments': frames_in_segments,  # NEU!
                    'feature_dim': feature_dim,
                    'total_videos': total_videos,
                    'total_segments': total_segments,
                    'avg_frames_per_segment': frames_in_segments / total_segments if total_segments > 0 else 0,  # NEU!
                    'file_size_gb': file_size,
                    'video_ids_ok': video_ids_ok,
                    'path': str(self.hdf5_path)
                }
        except Exception as e:
            logger.error(f"Fehler beim Lesen der Stats: {e}")
            return {
                'total_frames': 0,
                'frames_in_segments': 0,
                'feature_dim': 0,
                'total_videos': 0,
                'total_segments': 0,
                'avg_frames_per_segment': 0,
                'file_size_gb': 0,
                'video_ids_ok': False,
                'path': str(self.hdf5_path)
            }
    
    def backup(self) -> Path:
        """Erstellt ein Backup der Datenbank"""
        return BackupManager.create_backup(self.hdf5_path, "manual")

