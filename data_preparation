class BackupManager:
    """Erzwingt regelmäßige Backups"""
    
    @staticmethod
    def check_and_backup(hdf5_path: Path):
        """Prüft ob Backup nötig und führt es durch"""
        today = datetime.now()
        
        # Backup am 1. jedes Monats ZWINGEND
        if today.day == 1:
            logger.info("📅 Monatserster - ZWANGS-Backup wird erstellt!")
            BackupManager.create_backup(hdf5_path, "monthly")
        
        # Backup wenn Datei > 10GB gewachsen
        backup_log = config.BACKUP_DIR / "backup_log.json"
        if backup_log.exists():
            with open(backup_log, 'r') as f:
                last_backup = json.load(f)
            last_size = last_backup.get('size', 0)
            current_size = os.path.getsize(hdf5_path)
            
            if current_size - last_size > 10 * 1024 * 1024 * 1024:  # 10GB
                logger.info("💾 10GB gewachsen - Backup wird erstellt!")
                BackupManager.create_backup(hdf5_path, "growth")
    
    @staticmethod
    def create_backup(hdf5_path: Path, reason: str):
        """Erstellt Backup intern + extern"""
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        
        # Internes Backup
        internal_path = config.BACKUP_DIR / f"lip_dataset_{timestamp}_{reason}.h5"
        shutil.copy2(hdf5_path, internal_path)
        logger.info(f"💾 Internes Backup: {internal_path}")
        
        # Externes Backup (ZWANG!)
        try:
            external_path = config.EXTERNAL_BACKUP_DIR / f"lip_dataset_{timestamp}_{reason}.h5"
            shutil.copy2(hdf5_path, external_path)
            logger.info(f"💾 Externes Backup: {external_path}")
        except Exception as e:
            logger.error(f"❌ Externes Backup fehlgeschlagen: {e}")
            logger.error("   ⚠️  WARNUNG: KEIN EXTERNES BACKUP!")
        
        # Log aktualisieren
        backup_log = config.BACKUP_DIR / "backup_log.json"
        with open(backup_log, 'w') as f:
            json.dump({
                'timestamp': timestamp,
                'reason': reason,
                'size': os.path.getsize(hdf5_path),
                'internal': str(internal_path),
                'external': str(external_path) if 'external_path' in locals() else None
            }, f)

