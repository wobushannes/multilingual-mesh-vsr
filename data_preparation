class OptimizedFolderProcessor:
    def __init__(self, hdf5_db: OptimizedHDF5Database, num_workers: int = None):
        self.hdf5_db = hdf5_db
        self.num_workers = num_workers if num_workers else config.NUM_WORKERS
        self.stop_requested = False
        
    def stop(self):
        self.stop_requested = True
        logger.warning("⏹ Stopp angefordert...")
        
    def process_folder_parallel(self, folder_path: str, callback=None) -> int:
        """
        Verarbeitet mehrere Videos parallel - NULL TOLERANZ
        """
        folder = Path(folder_path)
        if not folder.exists():
            msg = f"❌ Ordner nicht gefunden: {folder_path}"
            logger.error(msg)
            if callback: callback(msg)
            return 0
        
        # Alle Videodateien finden
        video_files = []
        for ext in ['*.mp4', '*.avi', '*.mov', '*.mkv', '*.webm']:
            video_files.extend(folder.glob(ext))
            video_files.extend(folder.glob(ext.upper()))
        
        video_files = sorted(list(set(video_files)))
        
        msg = f"\n📁 Gefundene Videos: {len(video_files)}"
        logger.info(msg)
        if callback: callback(msg)
        
        if not video_files:
            return 0
            
        success_count = 0
        futures = []
        
        # Videos parallel verarbeiten (aber weniger Workers für Stabilität)
        with ThreadPoolExecutor(max_workers=self.num_workers) as executor:
            for video_path in video_files:
                if self.stop_requested:
                    break
                    
                # Eigene Instanzen für jeden Thread
                hdf5_db = OptimizedHDF5Database(self.hdf5_db.hdf5_path)
                processor = OptimizedVideoProcessor(hdf5_db)
                
                future = executor.submit(
                    processor.process_video_pipelined,
                    str(video_path),
                    callback
                )
                futures.append((future, video_path.name))
            
            # Ergebnisse einsammeln
            for future, name in futures:
                try:
                    if future.result():
                        success_count += 1
                        msg = f"✅ {name} erfolgreich"
                    else:
                        msg = f"❌ {name} fehlgeschlagen"
                except Exception as e:
                    msg = f"❌ {name} Fehler: {e}"
                
                if callback:
                    callback(msg)
        
        msg = f"\n✅ ORDNER FERTIG: {success_count}/{len(video_files)} Videos"
        logger.success(msg)
        if callback: callback(msg)
        
        return success_count

