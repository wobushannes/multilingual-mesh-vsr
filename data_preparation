class OptimizedMediaPipeProcessor:
    def __init__(self):
        self.face_landmarker = None
        self.input_dim = None
        self.frame_counter = 0
        self.fps = 25.0
        self.stats = {
            'frames_processed': 0,
            'frames_success': 0,
            'frames_black': 0,
            'frames_too_dark': 0,
            'frames_no_face': 0,
            'frames_face_cropped': 0,
            'frames_too_small': 0,
            'frames_invalid_landmarks': 0,
            'frames_error': 0
        }
        self.model_path = self._download_model()
        
    def _download_model(self) -> Path:
        """Lädt das FaceLandmarker Modell herunter falls nicht vorhanden"""
        model_path = config.MODELS_DIR / "face_landmarker.task"
        
        if not model_path.exists():
            logger.info("Lade FaceLandmarker Modell herunter...")
            url = "https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task"
            
            try:
                urllib.request.urlretrieve(url, model_path)
                logger.info(f"✅ Modell heruntergeladen: {model_path}")
            except Exception as e:
                logger.error(f"❌ Fehler beim Download: {e}")
        
        return model_path
        
    def initialize(self):
        """Initialisiert MediaPipe FaceLandmarker mit explizitem Modell"""
        try:
            from mediapipe.tasks import python
            from mediapipe.tasks.python.vision import FaceLandmarker, FaceLandmarkerOptions, RunningMode
            
            if not self.model_path.exists():
                logger.error(f"Modell nicht gefunden: {self.model_path}")
                return False
            
            options = FaceLandmarkerOptions(
                base_options=python.BaseOptions(model_asset_path=str(self.model_path)),
                running_mode=RunningMode.VIDEO,
                num_faces=config.MAX_FACES,
                min_face_detection_confidence=config.FACE_DETECTION_CONFIDENCE,
                min_face_presence_confidence=config.FACE_DETECTION_CONFIDENCE,
                min_tracking_confidence=0.5,  # Höher = stabiler
                output_face_blendshapes=False,
                output_facial_transformation_matrixes=False
            )
            
            self.face_landmarker = FaceLandmarker.create_from_options(options)
            self.frame_counter = 0
            logger.info("✅ MediaPipe Tasks API initialisiert (NULL TOLERANZ)")
            return True
            
        except Exception as e:
            logger.error(f"❌ MediaPipe Initialisierung fehlgeschlagen: {e}")
            self.face_landmarker = None
            return False
    
    def _check_frame_quality(self, frame: np.ndarray) -> bool:
        """Prüft ob Frame grundsätzlich brauchbar ist"""
        frame_mean = np.mean(frame)
        
        # Schwarzer Frame?
        if frame_mean < config.MAX_BLACK_FRAME_MEAN:
            self.stats['frames_black'] += 1
            return False
        
        # Zu dunkel?
        if frame_mean < config.MIN_FRAME_MEAN:
            self.stats['frames_too_dark'] += 1
            return False
        
        return True
    
    def _check_face_position(self, xs: List[float], ys: List[float], w: int, h: int) -> bool:
        """Prüft ob Gesicht vollständig im Bild ist"""
        if min(xs) < config.FACE_BORDER_MARGIN or max(xs) > w - config.FACE_BORDER_MARGIN:
            self.stats['frames_face_cropped'] += 1
            return False
        
        if min(ys) < config.FACE_BORDER_MARGIN or max(ys) > h - config.FACE_BORDER_MARGIN:
            self.stats['frames_face_cropped'] += 1
            return False
        
        return True
    
    def _check_landmarks(self, landmarks) -> bool:
        """Prüft ob alle Landmarks gültig sind"""
        for lm in landmarks:
            if lm.x < 0 or lm.x > 1 or lm.y < 0 or lm.y > 1:
                self.stats['frames_invalid_landmarks'] += 1
                return False
        return True
    
    def _process_single_frame(self, frame: np.ndarray, frame_idx: int) -> Optional[np.ndarray]:
        """Verarbeitet einen einzelnen Frame - NULL TOLERANZ"""
        self.stats['frames_processed'] += 1
        
        # 1. Frame-Qualität prüfen
        if not self._check_frame_quality(frame):
            return None
        
        if self.face_landmarker is None:
            if not self.initialize():
                self.stats['frames_error'] += 1
                return None
        
        try:
            import mediapipe as mp
            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)
            
            detection_result = self.face_landmarker.detect_for_video(mp_image, frame_idx)
            self.frame_counter += 1
            
            # 2. Face vorhanden?
            if not detection_result or not detection_result.face_landmarks:
                self.stats['frames_no_face'] += 1
                return None
            
            landmarks = detection_result.face_landmarks[0]
            
            # 3. Landmarks gültig?
            if not self._check_landmarks(landmarks):
                return None
            
            h, w = frame.shape[:2]
            xs = [lm.x * w for lm in landmarks]
            ys = [lm.y * h for lm in landmarks]
            
            # 4. Face-Position prüfen
            if not self._check_face_position(xs, ys, w, h):
                return None
            
            # 5. Face-Größe prüfen
            face_width = max(xs) - min(xs)
            face_height = max(ys) - min(ys)
            min_dim = config.MIN_FACE_SIZE * min(w, h)
            
            if face_width < min_dim or face_height < min_dim:
                self.stats['frames_too_small'] += 1
                return None
            
            # ALLE Prüfungen bestanden - Feature extrahieren
            features = []
            for lm in landmarks:
                features.extend([lm.x, lm.y, lm.z])
            
            feature_array = np.array(features, dtype=np.float32)
            
            if self.input_dim is None:
                self.input_dim = len(feature_array)
                logger.info(f"📐 Feature-Dimension: {self.input_dim}")
                config.INPUT_DIM = self.input_dim
            
            self.stats['frames_success'] += 1
            return feature_array
            
        except Exception as e:
            self.stats['frames_error'] += 1
            if self.stats['frames_error'] % 100 == 0:
                logger.error(f"MediaPipe Fehler: {str(e)}")
            return None
    
    def process_batch(self, frames: List[np.ndarray], start_idx: int) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
        """Verarbeitet einen BATCH von Frames"""
        batch_landmarks = []
        batch_indices = []
        batch_timestamps = []
        
        for i, frame in enumerate(frames):
            frame_idx = start_idx + i
            landmarks = self._process_single_frame(frame, frame_idx)
            if landmarks is not None:
                batch_landmarks.append(landmarks)
                batch_indices.append(frame_idx)
                batch_timestamps.append(frame_idx / self.fps)
        
        if batch_landmarks:
            return np.array(batch_landmarks), np.array(batch_indices), np.array(batch_timestamps)
        else:
            return np.array([]), np.array([]), np.array([])
    
    def get_stats(self) -> dict:
        total = self.stats['frames_processed']
        return {
            'processed': total,
            'success': self.stats['frames_success'],
            'black': self.stats['frames_black'],
            'too_dark': self.stats['frames_too_dark'],
            'no_face': self.stats['frames_no_face'],
            'face_cropped': self.stats['frames_face_cropped'],
            'too_small': self.stats['frames_too_small'],
            'invalid_landmarks': self.stats['frames_invalid_landmarks'],
            'errors': self.stats['frames_error'],
            'success_rate': (self.stats['frames_success'] / max(1, total)) * 100,
            'input_dim': self.input_dim
        }
    
    def reset_stats(self):
        self.stats = {k: 0 for k in self.stats}
    
    def close(self):
        if self.face_landmarker:
            try:
                self.face_landmarker.close()
            except:
                pass
            self.face_landmarker = None

