    def log(self, msg: str):
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.log_text.insert("end", f"[{timestamp}] {msg}\n")
        self.log_text.see("end")
        self.window.update()
    
    def start_randomize(self):
        folder = self.folder_var.get()
        if not folder:
            messagebox.showerror("Fehler", "Bitte Ordner auswählen!")
            return
        
        if not self.dry_run.get():
            if not messagebox.askyesno("WARNUNG", 
                "Dateien werden dauerhaft umbenannt!\n\nWirklich fortfahren?"):
                return
        
        self.start_btn.config(state="disabled")
        self.progress.start()
        
        extensions = [e.strip() for e in self.extensions_var.get().split(',') if e.strip()]
        
        def run():
            try:
                FileRandomizer.randomize_folder(
                    folder, extensions, self.name_length.get(),
                    self.dry_run.get(), self.log
                )
            finally:
                self.window.after(0, self.finished)
        
        thread = threading.Thread(target=run, daemon=True)
        thread.start()
    
    def finished(self):
        self.progress.stop()
        self.start_btn.config(state="normal")

